# ============================================================
# Environment Variables — copy this to .env.local and fill in
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# Secret key — NEVER expose this on the client. Server-side only.
SUPABASE_SECRET_DEFAULT_KEY=your-secret-key-here

# --- Claude Code ---
# Get your API key from: https://console.anthropic.com/settings/keys
# This is sourced into the shell automatically so `claude` skips the login prompt.
ANTHROPIC_API_KEY=your-api-key-here

# --- Auth (optional extras) ---
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-here
